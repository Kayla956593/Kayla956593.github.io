		else if(target[2]-z[zz]>650){settings.fogAmount=0.65;}
		else if(target[2]-z[zz]>650){settings.fogAmount=0.65;}
		else if(target[2]-z[zz]>650){settings.fogAmount=0.65;}
		else if(target[2]-z[zz]>600){settings.fogAmount=0.6;}
		else if(target[2]-z[zz]>550){settings.fogAmount=0.55;}
		else if(target[2]-z[zz]>500){settings.fogAmount=0.5;}
